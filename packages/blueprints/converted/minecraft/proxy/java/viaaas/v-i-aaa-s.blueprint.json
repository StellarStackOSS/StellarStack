{
  "schemaVersion": 1,
  "name": "VIAaaS",
  "author": "regulad@outlook.com",
  "description": "VIAaaS - ViaVersion as a Service - Standalone ViaVersion proxy",
  "dockerImages": {
    "Java 22": "ghcr.io/ptero-eggs/yolks:java_22",
    "Java 21": "ghcr.io/ptero-eggs/yolks:java_21",
    "Java 17": "ghcr.io/ptero-eggs/yolks:java_17",
    "Java 16": "ghcr.io/ptero-eggs/yolks:java_16",
    "Java 11": "ghcr.io/ptero-eggs/yolks:java_11",
    "Java 8": "ghcr.io/ptero-eggs/yolks:java_8"
  },
  "stopSignal": "^end",
  "startupCommand": "java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}} -sslPort={{WEBSERVER_PORT}}",
  "configFiles": [
    {
      "path": "config/viaaas.yml",
      "parser": "yaml",
      "patches": {
        "port": "{{SERVER_PORT}}",
        "bind-address": "0.0.0.0"
      }
    }
  ],
  "variables": [
    {
      "key": "SERVER_JARFILE",
      "name": "VIAaaS JAR File",
      "description": "The name of the JAR file to be used when downloading & running VIAaaS.",
      "default": "VIAaaS-all.jar",
      "userViewable": true,
      "userEditable": true,
      "rules": "required|string"
    },
    {
      "key": "WEBSERVER_PORT",
      "name": "Web Server Port",
      "description": "The port to listen to web server connections on.",
      "default": "25543",
      "userViewable": true,
      "userEditable": true,
      "rules": "required|string"
    }
  ],
  "install": {
    "image": "ghcr.io/ptero-eggs/installers:alpine",
    "entrypoint": "ash",
    "script": "#!/bin/ash\n# VIAaaS Installation Script\n#\n# Server Files: /mnt/server\ncd /mnt/server\nwget -O ${SERVER_JARFILE} \"https://jitpack.io/com/github/ViaVersion/VIAaaS/master-SNAPSHOT/VIAaaS-master-SNAPSHOT-all.jar\"\n\n## install end\necho \"-----------------------------------------\"\necho \"Installation completed...\"\necho \"-----------------------------------------\""
  },
  "lifecycle": {
    "starting": {
      "probes": [
        {
          "strategy": "console",
          "match": {
            "type": "substring",
            "value": "Application started in "
          }
        }
      ],
      "intervalMs": 2000,
      "timeoutMs": 120000,
      "onTimeout": "mark_crashed"
    },
    "stopping": {
      "probes": [
        {
          "strategy": "container_exit"
        }
      ],
      "graceTimeoutMs": 60000,
      "onTimeout": "force_kill"
    },
    "crashDetection": {
      "probes": [
        {
          "strategy": "container_exit",
          "ifNotInState": [
            "stopping",
            "stopped"
          ]
        }
      ]
    }
  },
  "features": [
    "eula",
    "java_version_picker",
    "pid_limit"
  ]
}