{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false,
      "inputs": ["src/**/*.ts", "drizzle.config.ts", ".env*"]
    },
    "db:migrate": {
      "cache": false,
      "inputs": ["src/**/*.ts", "drizzle.config.ts", "drizzle/**", ".env*"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "codegen:errors": {
      "inputs": ["locales/**/*.json", "scripts/codegen-errors.ts"],
      "outputs": ["src/error-codes.generated.ts"]
    }
  }
}
